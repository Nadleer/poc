#!/bin/bash

# A tiny calculator utility
# Usage: ./calc-tool <num1> <operator> <num2>

if [ "$#" -ne 3 ]; then
    echo "Usage: $0 <num1> <operator> <num2>"
    exit 1
fi

num1=$1
operator=$2
num2=$3

case $operator in
    +) echo "$num1 + $num2 = $((num1 + num2))" ;;
    -) echo "$num1 - $num2 = $((num1 - num2))" ;;
    \*) echo "$num1 * $num2 = $((num1 * num2))" ;;
    /)
        if [ "$num2" = "0" ]; then
            echo "Error: Division by zero"
            exit 1
        fi
        echo "$num1 / $num2 = $((num1 / num2))" ;;
    *) echo "Error: Invalid operator. Use +, -, *, or /" ; exit 1 ;;
esac
